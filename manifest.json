{
  "manifest_version": 3,
  "name": "RefStation",
  "version": "1.4",
  "description": "Curated reference images from Artstation in your new tabs.",
  "action": {
    "default_icon": "assets/img/icon.png",
    "default_title": "Go to Artstation"
  },
  "background": {
    "service_worker": "assets/js/background.js"
  },
  "chrome_url_overrides": {
    "newtab": "artstation.html"
  },
  "icons": {
    "48": "assets/img/icon.png"
  },
  "permissions": ["cookies", "downloads"],
  "host_permissions": [
    "https://www.artstation.com/*",
    "https://cdnb.artstation.com/*",
    "https://cdna.artstation.com/*",
    "https://fonts.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/css/*",
        "assets/js/*",
        "assets/img/*",
        "assets/fonts/*",
        "offline/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}